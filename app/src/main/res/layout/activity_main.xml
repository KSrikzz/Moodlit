<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d0b"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📡 Mood Lit"
            android:textSize="22sp"
            android:textColor="#E8E6E2"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Real-time LED trigger on incoming call"
            android:textSize="12sp"
            android:textColor="#6b6a67"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP SERVER IP"
            android:textColor="#4f98a3"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/et_server"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:textColor="#E8E6E2"
                android:hint="192.168.x.x"
                android:textColorHint="#444"
                android:background="#1a1917"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="text"
                android:textSize="14sp"/>

            <Button
                android:id="@+id/btn_save_ip"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Save"
                android:layout_marginStart="8dp"
                android:backgroundTint="#4f98a3"
                android:textColor="#fff"/>

            <Button
                android:id="@+id/btn_test"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Test"
                android:layout_marginStart="6dp"
                android:backgroundTint="#222120"
                android:textColor="#aaa"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2e2d2b"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUMBER → CATEGORY"
            android:textColor="#4f98a3"
            android:textSize="11sp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="#1a1917"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Spinner
                android:id="@+id/spinner_country_code"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="4dp"/>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#2e2d2b"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/et_number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:textColor="#E8E6E2"
                android:hint="9876543210"
                android:textColorHint="#444"
                android:background="@android:color/transparent"
                android:paddingEnd="14dp"
                android:inputType="number"
                android:maxLength="10"
                android:textSize="14sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_pick_contacts"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="📁 Select Contacts"
            android:backgroundTint="#1a1917"
            android:textColor="#4f98a3"
            android:textSize="13sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SELECTED CONTACTS (0)"
            android:textColor="#4f98a3"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/selected_contacts_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1a1917"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <Spinner
            android:id="@+id/sp_category"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1a1917"
            android:popupBackground="#1a1917"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_add"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="＋  Add to Category"
            android:backgroundTint="#4f98a3"
            android:textColor="#fff"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2e2d2b"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CURRENT MAPPINGS"
            android:textColor="#4f98a3"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/contact_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1a1917"
            android:padding="14dp"
            android:layout_marginBottom="20dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2e2d2b"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initialising..."
            android:textColor="#4f98a3"
            android:textSize="13sp"
            android:padding="14dp"
            android:background="#111"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2e2d2b"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_user_dashboard"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="👤 My Dashboard"
                android:backgroundTint="#1a1917"
                android:textColor="#4f98a3"
                android:textSize="13sp"
                android:layout_marginEnd="6dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
