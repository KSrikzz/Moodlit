<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d0b"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <TextView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← "
                android:textColor="#4f98a3"
                android:textSize="18sp"
                android:paddingEnd="8dp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👤 My Dashboard"
                android:textColor="#E8E6E2"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1917"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧘 Anxiety-Free Mode"
                    android:textColor="#E8E6E2"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_anxiety_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Only Family &amp; Friends will glow"
                    android:textColor="#6b6a67"
                    android:textSize="12sp"/>
            </LinearLayout>
            <Switch
                android:id="@+id/sw_anxiety"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#4f98a3"
                android:trackTint="#2e2d2b"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DO NOT DISTURB"
            android:textColor="#4f98a3"
            android:textSize="11sp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1917"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🚫 Toxic / Avoiding"
                android:textColor="#e74c3c"
                android:textSize="14sp"/>
            <Switch
                android:id="@+id/sw_dnd_toxic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#e74c3c"
                android:trackTint="#2e2d2b"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1917"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💼 Work"
                android:textColor="#4f98a3"
                android:textSize="14sp"/>
            <Switch
                android:id="@+id/sw_dnd_work"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#4f98a3"
                android:trackTint="#2e2d2b"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1917"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⭐ Friends"
                android:textColor="#f1c40f"
                android:textSize="14sp"/>
            <Switch
                android:id="@+id/sw_dnd_friends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#f1c40f"
                android:trackTint="#2e2d2b"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1917"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🏠 Family"
                android:textColor="#6daa45"
                android:textSize="14sp"/>
            <Switch
                android:id="@+id/sw_dnd_family"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#6daa45"
                android:trackTint="#2e2d2b"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CALL LOG"
            android:textColor="#4f98a3"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/card_toxic"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#1a1917"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚫"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/tv_count_toxic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#e74c3c"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_work"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#1a1917"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💼"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/tv_count_work"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#4f98a3"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_friends"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#1a1917"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/tv_count_friends"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#f1c40f"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_family"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#1a1917"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/tv_count_family"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#6daa45"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/log_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1a1917"
            android:padding="14dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_refresh_log"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="↻ Refresh Log"
            android:backgroundTint="#1a1917"
            android:textColor="#4f98a3"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>