<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d0d0b"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📁 Select Contacts"
        android:textColor="#E8E6E2"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/et_search_contact"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Search name or number"
        android:textColor="#E8E6E2"
        android:textColorHint="#6b6a67"
        android:background="#1a1917"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <ListView
        android:id="@+id/list_contacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#2e2d2b"
        android:dividerHeight="1dp"
        android:background="#1a1917"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn_cancel_contacts"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:backgroundTint="#222120"
            android:textColor="#aaa"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_done_contacts"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Use Selected"
            android:backgroundTint="#4f98a3"
            android:textColor="#fff"/>
    </LinearLayout>

</LinearLayout>
